x 6px 0 0;line-height:24px;bottom:0;height:24px;right:0;left:0;font-size:20px;justify-content:space-between;border-right:1px solid rgba(0,0,0,0.25);border-left:1px solid rgba(0,0,0,0.25);position:absolute;display:flex;border-top:1px solid rgba(0,0,0,0.25);z-index:100;align-items:flex-end;"><div style="color:#d3c7aa;flex:4 1 0px;text-align:center;font-weight:700;"><span title="28">Fright Night</span></div><div style="text-align:center;flex:1 1 0px;"><span class="plainlinks"><a target="_blank" rel="nofollow noreferrer noopener" class="external text" href="https://www.modelviewer.lol/model-viewer?id=221028"><span class="button" title="View in 3D" style="text-align:center; border-radius: 2px;"><b>View in 3D</b></span></a></span></div><div class="skinviewer-price" title="This skin is available to purchase with RP from the store."><a href="https://static.wikia.nocookie.net/leagueoflegends/images/0/00/RP_icon.png/revision/latest?cb=20241201161019" class="image" title="RP"><img alt="RP" src="data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D" decoding="async" loading="lazy" width="20" height="20" data-image-name="RP icon.png" data-image-key="RP_icon.png" data-relevant="0" data-src="https://static.wikia.nocookie.net/leagueoflegends/images/0/00/RP_icon.png/revision/latest/scale-to-width-down/20?cb=20241201161019" class="lazyload" /></a> 1350</div><div style="text-align:center;padding-right:2px;color:#c9aa71;flex:1 1 0px;font-size:smaller;">25.09.2024</div></div></div><div class="skinviewer-info" style="background-color:rgba(0, 0, 0, 0.1);padding:15px;font-family:BeaufortLoL;font-size:14px;"><div class="skinviewer-info-lore"><div style="line-height: 1.6em; text-align: center; font-size: 15px;">Head counselor, nurse, and necromancer at Creepaway Camp, Zeri wears many hats. Always ready to graft a hand or stitch up a mess, Zeri never leaves a camper behind. So when she drowned, campers put on their thinking caps and did as she had taught: a few stitches, a ZAP, and Zeri was back!</div><div><div class="center"><div class="floatnone"><img alt="Separator" src="data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D" decoding="async" loading="lazy" width="400" height="7" data-image-name="Separator.png" data-image-key="Separator.png" data-relevant="0" data-src="https://static.wikia.nocookie.net/leagueoflegends/images/1/10/Separator.png/revision/latest/scale-to-width-down/400?cb=20180110165522" class="lazyload" /></div></div></div></div><div class="skinviewer-info-kleine-bilder" style="display:flex;justify-content:center;"><div style="padding-right:1em; text-align:center;"><img alt="Actor" src="data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D" decoding="async" loading="lazy" width="20" height="20" data-image-name="Actor.png" data-image-key="Actor.png" data-relevant="0" data-src="https://static.wikia.nocookie.net/leagueoflegends/images/a/a9/Actor.png/revision/latest/scale-to-width-down/20?cb=20180529054842" class="lazyload" />Vanille Velasquez</div><div style="padding-right:1em; text-align:center;"><img alt="Artist" src="data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D" decoding="async" loading="lazy" width="20" height="20" data-image-name="Artist.png" data-image-key="Artist.png" data-relevant="0" data-src="https://static.wikia.nocookie.net/leagueoflegends/images/a/a5/Artist.png/revision/latest/scale-to-width-down/20?cb=20180528201217" class="lazyload" />Yuyu Wong, Kudos&#160;Productions</div><div style="padding-right:1em; text-align:center;"><img alt="Set piece" src="data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D" decoding="async" loading="lazy" width="20" height="20" data-image-name="Set piece.png" data-image-key="Set_piece.png" data-relevant="0" data-src="https://static.wikia.nocookie.net/leagueoflegends/images/5/5d/Set_piece.png/revision/latest/scale-to-width-dow