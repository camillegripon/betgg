<div class="skill skill_r" style="padding: 1em; margin-top: 1em; font-size:14px;box-shadow:black 0 2px 5px 0;color:#c8c4bd; border:#525244 solid 1px; background:#061e36 no-repeat right top; overflow:hidden; position:relative; z-index: 100;">
