splay:inline-block"><span class="inline-image tft-icon" style="display:inline;white-space:pre;" data-param="Whispers Emblem" data-type="item" data-set="7"><span class="border" style="display:inline-block;position:relative;" data-width="46"><a href="/wiki/Whispers_Emblem_(Teamfight_Tactics)#Set_7" title="Whispers Emblem (Teamfight Tactics)"><img alt="Whispers Emblem TFT item" src="data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D" decoding="async" loading="lazy" width="46" height="46" class="thumbborder lazyload" data-image-name="Whispers Emblem TFT item.png" data-image-key="Whispers_Emblem_TFT_item.png" data-relevant="0" data-src="https://static.wikia.nocookie.net/leagueoflegends/images/c/c7/Whispers_Emblem_TFT_item.png/revision/latest/scale-to-width-down/46?cb=20220717212637" /></a></span></span></li><li style="display:inline-block"><span class="inline-image tft-icon" style="display:inline;white-space:pre;" data-param="Youmuu&#39;s Ghostblade" data-type="item" data-set="4.5"><span class="border" style="display:inline-block;position:relative;" data-width="46"><a href="/wiki/Youmuu%27s_Ghostblade_(Teamfight_Tactics)#Set_4.5" title="Youmuu&#39;s Ghostblade (Teamfight Tactics)"><img alt="Youmuu&#39;s Ghostblade TFT item" src="data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D" decoding="async" loading="lazy" width="46" height="46" class="thumbborder lazyload" data-image-name="Youmuu&#39;s Ghostblade item old2.png" data-image-key="Youmuu%27s_Ghostblade_item_old2.png" data-relevant="0" data-src="https://static.wikia.nocookie.net/leagueoflegends/images/a/af/Youmuu%27s_Ghostblade_item_old2.png/revision/latest/scale-to-width-down/46?cb=20201016165434" /></a></span></span></li><li style="display:inline-block"><span class="inline-image tft-icon" style="display:inline;white-space:pre;" data-param="Yuumi" data-type="item" data-set="1"><span class="border" style="display:inline-block;position:relative;" dat