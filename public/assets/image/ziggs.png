		<h3 class="pi-data-label pi-secondary-font">SPEED:</h3>
	
	<div class="pi-data-value pi-font"><span class="basic-tooltip" style="border-bottom:1px dotted gray;cursor:help;" title="Missile speed">1750</span></div>
</div>

